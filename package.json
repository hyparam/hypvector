{
  "name": "hypvector",
  "version": "0.1.1",
  "description": "Vector similarity search directly over Parquet files",
  "author": "Hyperparam",
  "homepage": "https://hyperparam.app",
  "license": "MIT",
  "keywords": [
    "parquet",
    "vector",
    "embedding",
    "similarity-search",
    "ann",
    "hyparquet",
    "serverless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyparam/hypvector.git"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "hypvector": "./bin/cli.js"
  },
  "types": "src/index.d.ts",
  "main": "src/index.js",
  "export": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "benchmark": "node benchmark.js",
    "coverage": "vitest run --coverage --coverage.include=src",
    "data:download": "node scripts/download.js",
    "data:embed": "node scripts/embed.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "hyparquet": "1.26.1",
    "hyparquet-compressors": "1.1.1",
    "hyparquet-writer": "0.16.1"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-plugin-jsdoc": "63.0.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
